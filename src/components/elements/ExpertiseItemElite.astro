---
interface Props {
  title: string;
  description: string;
  percent: number;
}
const { title, description, percent } = Astro.props;

const RADIUS = 42;
const CIRCUMFERENCE = 2 * Math.PI * RADIUS;
const dashOffset = CIRCUMFERENCE * (1 - percent / 100);
---
<div class="expertise-item-elite">
  <div class="expertise-item-elite__ring">
    <svg viewBox="0 0 100 100" aria-hidden="true">
      <g class="expertise-item-elite__ring-rotate">
        <circle class="expertise-item-elite__ring-track" cx="50" cy="50" r={RADIUS}></circle>
        <circle
          class="expertise-item-elite__ring-progress"
          cx="50"
          cy="50"
          r={RADIUS}
          style={`stroke-dasharray: ${CIRCUMFERENCE.toFixed(1)}; stroke-dashoffset: ${dashOffset.toFixed(1)};`}
        ></circle>
      </g>
      <circle class="expertise-item-elite__ring-dot" cx="50" cy="8" r="4"></circle>
    </svg>
    <span class="expertise-item-elite__percent">{percent}%</span>
  </div>
  <div class="expertise-item-elite__content">
    <h3 class="expertise-item-elite__title">{title}</h3>
    <p class="expertise-item-elite__desc">{description}</p>
  </div>
</div>
