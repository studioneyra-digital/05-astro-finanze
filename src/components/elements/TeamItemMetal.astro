---
interface Props {
  name: string;
  role: string;
  photo: string;
}
const { name, role, photo } = Astro.props;
---
<div class="team-item-metal">
  <img class="team-item-metal__img" src={photo} alt={name} loading="lazy" />
  <span class="team-item-metal__scrim"></span>
  <div class="team-item-metal__info">
    <span class="team-item-metal__name">{name}</span>
    <span class="team-item-metal__role">{role}</span>
  </div>
  <div class="team-item-metal__social">
    <button type="button" class="team-item-metal__share" aria-label="Compartir perfil"><i data-lucide="share-2"></i></button>
    <a href="#" class="team-item-metal__social-link" aria-label="Instagram">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
    </a>
    <a href="#" class="team-item-metal__social-link" aria-label="X (Twitter)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l16 16M20 4L4 20"/></svg>
    </a>
    <a href="#" class="team-item-metal__social-link" aria-label="Facebook">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M15 4h-2a4 4 0 0 0-4 4v3H7v4h2v7h4v-7h3l1-4h-4V8a1 1 0 0 1 1-1h3z"/></svg>
    </a>
    <a href="#" class="team-item-metal__social-link" aria-label="Pinterest">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 20c1-3 2-9 2-9"/><path d="M9.5 12a3 3 0 1 1 4 2.8"/></svg>
    </a>
  </div>
</div>
