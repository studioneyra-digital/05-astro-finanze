---
import Tabs from '../elements/Tabs.astro';

const tabs = [
  { id: 'tab-panel-healthcare', label: 'Healthcare & Wellness', icon: 'gem' },
  { id: 'tab-panel-tech', label: 'Technology & IT Services', icon: 'binoculars' },
  { id: 'tab-panel-realestate', label: 'Real Estate & Construction', icon: 'drafting-compass' },
  { id: 'tab-panel-retail', label: 'Retail & E-commerce', icon: 'palette' },
];

const panels = [
  {
    id: 'tab-panel-healthcare',
    image: 'https://images.unsplash.com/photo-1551190822-a9333d879b1f?w=800&q=80',
    alt: 'Equipo revisando finanzas de salud',
    title: 'Financial Solutions for Healthcare and Wellness Excellence',
    description: 'We provide expert financial guidance and tailored consulting solutions for healthcare providers and wellness businesses, helping them optimize operations, manage costs, ensure compliance, and achieve sustainable growth.',
    checklist: [
      'Ensure adherence to healthcare regulations while minimizing financial risks.',
      'Implement long-term financial planning & investment strategies to support.',
      'Streamline budgeting, cost control and resource allocation for better efficiency.',
    ],
  },
  {
    id: 'tab-panel-tech',
    image: 'https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=800&q=80',
    alt: 'Equipo de tecnología revisando finanzas',
    title: 'Financial Solutions for Technology & IT Services Excellence',
    description: 'We provide expert financial guidance and tailored consulting solutions for tech companies, helping them scale operations, manage burn rate, ensure compliance, and achieve sustainable growth.',
    checklist: [
      'Ensure adherence to data & compliance regulations while minimizing financial risks.',
      'Implement long-term financial planning & investment strategies to support.',
      'Streamline budgeting, cost control and resource allocation for better efficiency.',
    ],
  },
  {
    id: 'tab-panel-realestate',
    image: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&q=80',
    alt: 'Consultoría financiera de bienes raíces',
    title: 'Financial Solutions for Real Estate & Construction Excellence',
    description: 'We provide expert financial guidance and tailored consulting solutions for developers and contractors, helping them manage cash flow, control project costs, and achieve sustainable growth.',
    checklist: [
      'Ensure adherence to regulations while minimizing financial risks.',
      'Implement long-term financial planning & investment strategies to support.',
      'Streamline budgeting, cost control and resource allocation for better efficiency.',
    ],
  },
  {
    id: 'tab-panel-retail',
    image: 'https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=800&q=80',
    alt: 'Consultoría financiera de retail',
    title: 'Financial Solutions for Retail & E-commerce Excellence',
    description: 'We provide expert financial guidance and tailored consulting solutions for retail and e-commerce brands, helping them optimize margins, manage inventory costs, and achieve sustainable growth.',
    checklist: [
      'Ensure adherence to regulations while minimizing financial risks.',
      'Implement long-term financial planning & investment strategies to support.',
      'Streamline budgeting, cost control and resource allocation for better efficiency.',
    ],
  },
];
---
<div class="tabs" data-tabs>
  <Tabs tabs={tabs} activeId={tabs[0].id} />

  {panels.map((panel, index) => (
    <div class:list={['tabs__panel', { 'is-active': index === 0 }]} id={panel.id} role="tabpanel">
      <div class="tabs__panel-card">
        <div class="tabs__panel-media">
          <img src={panel.image} alt={panel.alt} loading="lazy" />
        </div>
        <div class="tabs__panel-body">
          <h3 class="tabs__panel-title">{panel.title}</h3>
          <p class="tabs__panel-desc">{panel.description}</p>
          <hr class="tabs__panel-divider" />
          <ul class="tabs__checklist">
            {panel.checklist.map((point) => (
              <li><i data-lucide="check-circle"></i> {point}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  import { initTabs } from '../../scripts/tabs';
  const root = document.querySelector<HTMLElement>('[data-tabs]');
  if (root) initTabs(root);
</script>
