---
import type { CollectionEntry } from 'astro:content';
import GoogleRatingBox from '../elements/GoogleRatingBox.astro';

interface Props {
  eyebrow: string;
  heading: string;
  description: string;
  ratingScore: string;
  reviewCount: number;
  testimonials: CollectionEntry<'testimonials'>[];
}
const { eyebrow, heading, description, ratingScore, reviewCount, testimonials } = Astro.props;
---
<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="testimonials__header-row">
      <div class="section-header">
        <span class="eyebrow"><span class="eyebrow__line"></span>{eyebrow}</span>
        <h2 class="section-header__title">{heading}</h2>
        <p class="section-header__desc">{description}</p>
      </div>

      <GoogleRatingBox score={ratingScore} reviewCount={reviewCount} />
    </div>

    <div class="row g-4">
      {testimonials.map((testimonial) => (
        <div class="col-12 col-lg-4">
          <div class="testimonial-item testimonial-item--light">
            <div class="testimonial-item__header">
              <img class="testimonial-item__avatar" src={testimonial.data.avatar} alt={testimonial.data.name} loading="lazy" />
              <div class="testimonial-item__person">
                <span class="testimonial-item__name">{testimonial.data.name}</span>
                <span class="testimonial-item__role">{testimonial.data.role}</span>
              </div>
            </div>
            <div class="testimonial-item__stars" aria-label={`${testimonial.data.rating} de 5 estrellas`}>
              {Array.from({ length: 5 }).map(() => <i data-lucide="star"></i>)}
            </div>
            <p class="testimonial-item__quote">"{testimonial.data.quote}"</p>
            {testimonial.data.stat && testimonial.data.statCaption && (
              <>
                <hr class="testimonial-item__divider" />
                <div class="testimonial-item__stat">
                  <span class="testimonial-item__stat-value">{testimonial.data.stat}<span class="testimonial-item__stat-percent">%</span></span>
                  <p class="testimonial-item__stat-caption">{testimonial.data.statCaption}</p>
                </div>
              </>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
