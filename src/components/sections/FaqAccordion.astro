---
interface Item {
  question: string;
  answer: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---
<div class="faq-list" data-faq>
  {items.map((item, index) => (
    <div class:list={['faq-item', { 'is-active': index === 0 }]}>
      <button class="faq-item__question" type="button" aria-expanded={index === 0} aria-controls={`faq-answer-${index}`}>
        <span>{item.question}</span>
        <span class="faq-item__icon">
          <i data-lucide="plus" class="faq-item__icon-plus"></i>
          <i data-lucide="minus" class="faq-item__icon-minus"></i>
        </span>
      </button>
      <div class="faq-item__answer" id={`faq-answer-${index}`}>
        <div class="faq-item__answer-inner">
          <p>{item.answer}</p>
        </div>
      </div>
    </div>
  ))}
</div>

<script>
  import { initFaqAccordion } from '../../scripts/faqAccordion';
  const faq = document.querySelector<HTMLElement>('[data-faq]');
  if (faq) initFaqAccordion(faq);
</script>
