---
import type { CollectionEntry } from 'astro:content';
import CardServiceItem from '../elements/CardServiceItem.astro';

interface Props {
  eyebrow: string;
  heading: string;
  description: string;
  services: CollectionEntry<'services'>[];
}
const { eyebrow, heading, description, services } = Astro.props;
---
<section class="our-services" id="services">
  <div class="container">
    <div class="section-header section-header--dark">
      <span class="eyebrow"><span class="eyebrow__line"></span>{eyebrow}</span>
      <h2 class="section-header__title">{heading}</h2>
      <p class="section-header__desc">{description}</p>
    </div>

    <div class="services-slider">
      <div class="services-slider__swiper swiper">
        <div class="swiper-wrapper">
          {services.map((service) => (
            <div class="swiper-slide">
              <CardServiceItem
                title={service.data.title}
                icon={service.data.icon}
                description={service.data.description}
                image={service.data.image}
                href={`/servicios/${service.slug}`}
              />
            </div>
          ))}
        </div>
      </div>
      <div class="services-slider__pagination"></div>
    </div>
  </div>
</section>

<script>
  import { initServicesSlider } from '../../scripts/servicesSlider';
  initServicesSlider();
</script>
