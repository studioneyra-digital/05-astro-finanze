---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import PostCard from '../../components/elements/PostCard.astro';
import Newsletter from '../../components/elements/Newsletter.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---
<PageLayout
  title="Blog | Finanze"
  description="Ideas y estrategias sobre finanzas y consultoría de negocios."
  subHeroTitle="Blog"
  breadcrumb={[{ label: 'Inicio', href: '/' }, { label: 'Blog' }]}
  ctaHeading="¿Tienes preguntas sobre tu negocio?"
  ctaDescription="Agenda una sesión con nuestro equipo y descubre cómo podemos ayudarte a crecer."
  ctaPrimaryLabel="Contáctanos"
  ctaPrimaryHref="/contacto"
>
  <div class="container">
    <div class="row g-4">
      {posts.map((post) => (
        <div class="col-12 col-sm-6 col-lg-4">
          <PostCard title={post.data.title} image={post.data.image} href={`/blog/${post.slug}`} />
        </div>
      ))}
    </div>
  </div>
  <Newsletter
    heading="Recibe insights de estrategia financiera"
    description="Análisis, tendencias y casos de estudio cada dos semanas. Sin spam, solo valor."
  />
</PageLayout>
